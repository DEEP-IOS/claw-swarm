{
  "name": "claw-swarm",
  "version": "5.0.0",
  "description": "Claw-Swarm V5.0 — 蜂群智能插件 / Swarm intelligence plugin for OpenClaw with 6-layer architecture",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "src/index.js",
  "openclaw": {
    "extensions": ["./src/index.js"]
  },
  "exports": {
    ".": "./src/index.js",
    "./infrastructure/*": "./src/L1-infrastructure/*",
    "./communication/*": "./src/L2-communication/*",
    "./agent/*": "./src/L3-agent/*",
    "./orchestration/*": "./src/L4-orchestration/*",
    "./application/*": "./src/L5-application/*",
    "./monitoring/*": "./src/L6-monitoring/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:stress": "vitest run tests/stress/",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:L1": "vitest run tests/unit/L1/",
    "test:L2": "vitest run tests/unit/L2/",
    "test:L3": "vitest run tests/unit/L3/",
    "test:L4": "vitest run tests/unit/L4/",
    "test:L5": "vitest run tests/unit/L5/",
    "test:L6": "vitest run tests/unit/L6/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DEEP-IOS/claw-swarm.git"
  },
  "bugs": {
    "url": "https://github.com/DEEP-IOS/claw-swarm/issues"
  },
  "homepage": "https://github.com/DEEP-IOS/claw-swarm#readme",
  "author": "DEEP-IOS",
  "license": "MIT",
  "keywords": [
    "swarm",
    "multi-agent",
    "governance",
    "pheromone",
    "openclaw",
    "plugin",
    "memory",
    "bio-inspired",
    "stigmergy",
    "agent-design",
    "soul",
    "collaboration",
    "knowledge-graph",
    "moe",
    "contract-net",
    "abc-algorithm"
  ],
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "fastify": "^5.2.1",
    "nanoid": "^5.1.2",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  },
  "files": [
    "src/",
    "docs/",
    "openclaw.plugin.json",
    "LICENSE",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md"
  ]
}
