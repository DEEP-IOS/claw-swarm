{
  "name": "claw-swarm",
  "version": "4.0.0",
  "description": "蜂群 Claw-Swarm — Unified swarm intelligence plugin for OpenClaw: memory, pheromones, governance, and agent design",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./core/*": "./src/layer1-core/*",
    "./engines/*": "./src/layer2-engines/*",
    "./intelligence/*": "./src/layer3-intelligence/*"
  },
  "scripts": {
    "test": "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:stress": "node --test tests/stress/*.test.js",
    "test:migration": "node --test tests/integration/db-migration.test.js",
    "test:all": "node --test tests/unit/*.test.js tests/integration/*.test.js tests/stress/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DEEP-IOS/claw-swarm.git"
  },
  "bugs": {
    "url": "https://github.com/DEEP-IOS/claw-swarm/issues"
  },
  "homepage": "https://github.com/DEEP-IOS/claw-swarm#readme",
  "author": "DEEP-IOS",
  "license": "MIT",
  "keywords": [
    "swarm",
    "multi-agent",
    "governance",
    "pheromone",
    "openclaw",
    "plugin",
    "memory",
    "bio-inspired",
    "stigmergy",
    "agent-design",
    "soul",
    "collaboration"
  ],
  "files": [
    "src/",
    "config/",
    "docs/",
    "LICENSE",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md"
  ]
}
